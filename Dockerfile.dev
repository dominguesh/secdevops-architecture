# Dev shell (Compose profile `tools` only): SSH; repo at /workspace.
# Kanban UI is served by compose service `frontend` → http://localhost:5173 — not this container.

FROM node:22-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        sudo \
        openssh-server \
        curl \
        ca-certificates \
        gnupg \
        docker.io \
    && useradd -m -s /bin/bash devuser \
    && echo "devuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers \
    && rm -rf /var/lib/apt/lists/*

# Optional: fails on some corporate TLS-intercept networks — image still builds; install `op` on host or add your CA.
RUN ( \
    set -e; \
    curl -fsSL https://downloads.1password.com/linux/keys/1password.asc \
      | gpg --dearmor -o /usr/share/keyrings/1password-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" \
      | tee /etc/apt/sources.list.d/1password.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends 1password-cli; \
    rm -rf /var/lib/apt/lists/*; \
  ) || echo "WARNING: 1password-cli not installed (TLS/proxy). Install on your dev machine or rebuild with trusted network."

RUN mkdir -p /var/run/sshd \
    && ssh-keygen -A \
    && sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config

RUN echo 'devuser:devpass' | chpasswd

WORKDIR /workspace

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D"]
